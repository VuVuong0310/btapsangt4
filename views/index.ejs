<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="logo">
                <h1>Flower Shop</h1>
            </div>
            <ul class="nav-links">
                <li><a href="/">Trang Chu</a></li>
                <li><a href="/products">San Pham</a></li>
                <li><a href="/about">Gioi Thieu</a></li>
                <li><a href="/contact">Lien He</a></li>
            </ul>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-content">
            <h2>Chao Mung Den Flower Shop</h2>
            <p>Nhung bo hoa tuoi dep nhat danh cho ban</p>
            <a href="/products" class="btn">Xem San Pham</a>
        </div>
    </section>

    <section class="featured">
        <h2>San Pham Noi Bat</h2>
        <div class="product-grid">
            <div class="product-card">
                <div class="product-image">🌹</div>
                <h3>Hoa Hong Do</h3>
                <p class="price">200.000 VND</p>
                <button class="btn">Mua Ngay</button>
            </div>
            <div class="product-card">
                <div class="product-image">🌷</div>
                <h3>Hoa Tulip</h3>
                <p class="price">250.000 VND</p>
                <button class="btn">Mua Ngay</button>
            </div>
            <div class="product-card">
                <div class="product-image">🌻</div>
                <h3>Hoa Huong Duong</h3>
                <p class="price">150.000 VND</p>
                <button class="btn">Mua Ngay</button>
            </div>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 Flower Shop. All rights reserved.</p>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
